# Nabu-плагин — пример переменных окружения. Скопировать в .env, не коммитить.

# ── Supabase (Postgres + pgvector) ──
# Прямое подключение для batch-пайплайна и MCP-серверов (config.ts требует DATABASE_URL)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
# Для интерактива через Supabase MCP (если используется)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── TypeDB (граф семантической/ассоциативной памяти, HTTP API 3.x) ──
TYPEDB_URL=https://<instance>.cluster.typedb.com:80
TYPEDB_DATABASE=nabu_dev
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=

# ── Локальный Ollama (приватные эмбеддинги, 768) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe:latest

# ── Облачные эмбеддинги (только для default-контента, опционально) ──
VOYAGE_API_KEY=

# ── Whisper (голос → текст) ──
WHISPER_MODEL=large-v3
# Диаризация (кто говорит) — опционально, требует HuggingFace токен и pyannote
ENABLE_DIARIZATION=false
HF_TOKEN=

# ── Прочее ──
NABU_NAMESPACE=default
# ID пользователя-владельца в общей многопользовательской БД (для доменных/аналитических
# таблиц основного Nabu: projects/habits/metrics/...). В общей БД задать ОБЯЗАТЕЛЬНО, иначе
# берётся первый пользователь (риск обращения к чужим данным). uuid из public.users.
NABU_USER_ID=
LOG_LEVEL=info
